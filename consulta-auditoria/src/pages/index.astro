  <button class="scroll-top" id="scrollTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>

  <script>
    (function(){
      const c=document.getElementById('heroCanvas');
      if(!c)return;
      const ctx=c.getContext('2d');
      let W=c.width=window.innerWidth,H=c.height=window.innerHeight;
      const pts=Array.from({length:60},()=>({
        x:Math.random()*W,y:Math.random()*H,
        vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,
        r:Math.random()*1.5+.5,
        a:Math.random()
      }));
      window.addEventListener('resize',()=>{W=c.width=window.innerWidth;H=c.height=window.innerHeight});
      function draw(){
        ctx.clearRect(0,0,W,H);
        pts.forEach(p=>{
          p.x+=p.vx;p.y+=p.vy;
          if(p.x<0||p.x>W)p.vx*=-1;
          if(p.y<0||p.y>H)p.vy*=-1;
          ctx.beginPath();
          ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
          ctx.fillStyle=`rgba(0,245,155,${p.a*.4})`;
          ctx.fill();
        });
        for(let i=0;i<pts.length;i++){
          for(let j=i+1;j<pts.length;j++){
            const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y;
            const d=Math.sqrt(dx*dx+dy*dy);
            if(d<120){
              ctx.beginPath();
              ctx.moveTo(pts[i].x,pts[i].y);
              ctx.lineTo(pts[j].x,pts[j].y);
              ctx.strokeStyle=`rgba(0,196,255,${(1-d/120)*.08})`;
              ctx.lineWidth=1;
              ctx.stroke();
            }
          }
        }
        requestAnimationFrame(draw);
      }
      draw();
    })();

    (function(){
      const statsEl = document.querySelector('.hero-stats');
      if (!statsEl) return;

      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;

          document.querySelectorAll('.stat-n[data-target]').forEach(el => {
            const target = +el.dataset.target;
            let v = 0;
            const step = target / 50;
            const t = setInterval(() => {
              v = Math.min(v + step, target);
              el.textContent = Math.round(v);
              if (v >= target) clearInterval(t);
            }, 25);
          });
          obs.disconnect(); // Disconnect after the animation has been triggered once.
        });
      }, { threshold: 0.5 });
      observer.observe(statsEl);
    })();

    window.addEventListener('scroll',()=>{
      const pct=window.scrollY/(document.documentElement.scrollHeight-window.innerHeight)*100;
      document.getElementById('progress').style.width=pct+'%';
      document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>50);
      document.getElementById('scrollTop').classList.toggle('visible',window.scrollY>400);

      document.querySelectorAll('section[id]').forEach(s=>{
        const a=document.querySelector(`.nav-links a[href="#${s.id}"]`);
        if(!a)return;
        a.classList.toggle('active',window.scrollY>=s.offsetTop-160&&window.scrollY<s.offsetTop+s.offsetHeight-160);
      });
    });

    const ham=document.getElementById('ham');
    const drawer=document.getElementById('drawer');
    const dOverlay=document.getElementById('dOverlay');
    const dClose=document.getElementById('dClose');
    function openDrawer(){drawer.classList.add('open');dOverlay.classList.add('open');ham.classList.add('open')}
    function closeDrawer(){drawer.classList.remove('open');dOverlay.classList.remove('open');ham.classList.remove('open')}
    ham.addEventListener('click',()=>drawer.classList.contains('open')?closeDrawer():openDrawer());
    dClose.addEventListener('click',closeDrawer);
    dOverlay.addEventListener('click',closeDrawer);
    drawer.querySelectorAll('a').forEach(a=>a.addEventListener('click',closeDrawer));

    const revObs=new IntersectionObserver(entries=>{
      entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');revObs.unobserve(e.target)}});
    },{threshold:.07});
    document.querySelectorAll('.rv').forEach(e=>revObs.observe(e));

    document.querySelectorAll('.acc-head').forEach(h=>{
      h.addEventListener('click',()=>{
        const item=h.closest('.acc-item');
        const wasOpen=item.classList.contains('open');
        item.closest('.acc')?.querySelectorAll('.acc-item').forEach(i=>i.classList.remove('open'));
        if(!wasOpen)item.classList.add('open');
      });
    });

    document.querySelectorAll('.tab-btn').forEach(b=>{
      b.addEventListener('click',()=>{
        const target=b.dataset.tab;
        const wrap=b.closest('.tabs-wrap');
        wrap.querySelectorAll('.tab-btn').forEach(x=>x.classList.remove('active'));
        wrap.querySelectorAll('.tab-panel').forEach(x=>x.classList.remove('active'));
        b.classList.add('active');
        document.getElementById(target)?.classList.add('active');
      });
    });

    document.querySelectorAll('.law-btn').forEach(b=>{
      b.addEventListener('click',()=>{
        const law=b.dataset.law;
        const wrap=b.closest('.laws-tabs');
        wrap.querySelectorAll('.law-btn').forEach(x=>x.classList.remove('active'));
        wrap.querySelectorAll('.law-panel').forEach(x=>x.classList.remove('active'));
        b.classList.add('active');
        document.getElementById(law)?.classList.add('active');
      });
    });

    const tip=document.getElementById('matTip');
    document.querySelectorAll('.mg-cell').forEach(c=>{
      c.addEventListener('mouseenter',()=>{
        tip.textContent=c.dataset.tip;
        tip.classList.add('show');
      });
      c.addEventListener('mousemove',e=>{
        tip.style.left=(e.clientX+14)+'px';
        tip.style.top=(e.clientY-30)+'px';
      });
      c.addEventListener('mouseleave',()=>tip.classList.remove('show'));
    });
  </script>
</body>
</html>